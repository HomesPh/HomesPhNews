# --- STORAGE CONFIGURATION ---
STORAGE_PROVIDER=aws

# Google Cloud Storage (GCP)
GCP_PROJECT_ID=your-project-id
GCP_BUCKET_NAME=your-bucket-name
# Paste the entire content of your service-account.json here as a single-line string
GCP_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id",...}

# Amazon S3
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=your-bucket-name
AWS_FOLDER=homestv

# --- DATABASE / CACHE ---
REDIS_URL=redis://localhost:6379/0

# --- AI SERVICES ---
# Google AI (Gemini) for Text Generation and Image Generation
GOOGLE_AI_API_KEY=your-google-ai-api-key

# Nano Banana (Image Generation - Alternative)
NANO_BANANA_API_KEY=your-nano-banana-api-key

# OpenAI (Text Generation GPT + Image Generation DALL-E - Fallback)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: OpenAI Configuration
# OPENAI_FALLBACK_ENABLED=true  # Enable/disable OpenAI fallback for text/image (default: true if API key is set)
# OPENAI_IMAGE_SIZE=1024x1024  # Options: 1024x1024, 1792x1024 (landscape) - for image generation only
# OPENAI_IMAGE_QUALITY=standard  # Options: standard, hd - for image generation only

# --- SCRAPER SETTINGS ---
NEWS_API_KEY=your-news-api-key
GOOGLE_NEWS_API_KEY=your-google-news-api-key
SCRAPER_KEYWORDS="Real Estate Philippines, Singapore Property News, Global Real Estate Trends"

DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# --- MYSQL DATABASE ---
DB_CONNECTION=mysql
DB_HOST=your-db-host
DB_PORT=3306
DB_DATABASE=your-database-name
DB_USERNAME=your-username
DB_PASSWORD=your-password
DATABASE_URL=mysql+pymysql://username:password@host:port/database
